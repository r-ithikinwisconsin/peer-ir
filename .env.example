# --- Supabase (local defaults printed by `supabase start`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- PostHog (optional; analytics is a no-op when unset) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Test-only login bypass (used by Playwright) ---
# Leave unset in production. Set to any random string locally to enable /api/test/login.
TEST_LOGIN_SECRET=
