# ─────────────────────────────────────────────────────────────
# DecIQ — docker compose env
# Copy to docker/.env and (optionally) rotate the JWT values.
# Defaults here are the same demo values published by Supabase
# for local self-host and are SAFE to commit for local dev.
# Do NOT use these values in production.
# ─────────────────────────────────────────────────────────────

# --- Postgres ---
POSTGRES_PASSWORD=postgres

# --- JWT (keep the secret + keys in sync; keys are HS256-signed by the secret) ---
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE3NjcyMjU2MDAsImV4cCI6MjA4MjY3MjAwMH0.xheE2-fAwI0V1voEqWqmAF7x129taRCETrSANVAyjWs
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTc2NzIyNTYwMCwiZXhwIjoyMDgyNjcyMDAwfQ.tfcmS_54IHEB-ExNyjhCR96hXTpOXGK-K0oM5undYWk

# --- Public URLs (what the *browser* sees) ---
SITE_URL=http://localhost:3000
SUPABASE_PUBLIC_URL=http://localhost:8000

# --- Test-only login bypass (leave blank to disable) ---
TEST_LOGIN_SECRET=

# --- PostHog (optional; analytics no-ops when blank) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
